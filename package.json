{
  "name": "vite-plugin-vue-type-resolver",
  "version": "0.0.0",
  "description": "Resolve Vue defineProps<T>() types with tsgo and rewrite them into finite type literals.",
  "license": "MIT",
  "author": "Edison",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack --dts",
    "dev": "vp pack --watch --dts",
    "test": "vp test",
    "typecheck": "vp check",
    "release": "bumpp",
    "prepublishOnly": "vp pack --dts"
  },
  "dependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@types/babel__traverse": "^7.28.0",
    "@vue/compiler-sfc": "^3.5.20",
    "magic-string": "^0.30.21",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260410.1",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
